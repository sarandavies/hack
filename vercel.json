{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --production=false",
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "public/**",
      "maxDuration": 30
    }
  }
}
