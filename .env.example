# Vector environment configuration (safe placeholders only — never commit real secrets)

NEXT_PUBLIC_APP_NAME=Vector
NEXT_PUBLIC_APP_TAGLINE=Find the account. Know why now.

# Live persistence (Neon-compatible PostgreSQL). Not required for synthetic demo mode.
DATABASE_URL=

# Operating modes
DEMO_MODE=true
LIVE_RESEARCH_ENABLED=false
DEMO_ACCESS_CODE=

# AI provider
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=

# Search / extraction providers
EXA_API_KEY=
BRAVE_SEARCH_API_KEY=
FIRECRAWL_API_KEY=

APP_URL=http://localhost:3000
ENABLE_DIAGNOSTICS=false

# Research configuration
DEFAULT_RESEARCH_MODE=fast
RESEARCH_QUALIFICATION_THRESHOLD=70
FAST_RUN_MAX_COST_USD=2.50
THOROUGH_RUN_MAX_COST_USD=10.00

# Precomputed real demo run (optional, requires live credentials)
REAL_DEMO_STARTUP_URL=

# Live evaluation batch (comma-separated URLs)
EVAL_STARTUP_URLS=

# Demo pacing (1 = real time; smaller = faster; used by tests/e2e)
DEMO_TIME_SCALE=1
